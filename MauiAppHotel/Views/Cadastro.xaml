<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Cadastro"
             Title="Cadastro">
    <!-- Container geral da tela -->
    <VerticalStackLayout Padding="10" Spacing="10" VerticalOptions="Center">
        <Label Text="Cadastro de Usuário" 
           HorizontalTextAlignment="Center"
           FontFamily="PoppinsRegular"
           FontSize="45"
           TextColor="{StaticResource Primary}"/>

        
        <Border Padding="10" StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Spacing="10">

                <Label Text="Email" />
                <Entry x:Name="entry_email" Placeholder="Digite seu email" />

                <Label Text="Senha" />
                <Entry x:Name="entry_senha" Placeholder="Digite sua senha" IsPassword="True" />

                <Label Text="Confirme a Senha" />
                <Entry x:Name="entry_confirmar_senha" Placeholder="Confirme sua senha" IsPassword="True" />

                <Button Text="Cadastrar" Clicked="Button_Clicked" />
                <Label HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Já tem uma conta? " FontSize="15" FontFamily="PoppinsRegular"/>
                            <Span Text="Faça o login!"
                 TextColor="Blue"
                 TextDecorations="Underline"
                 FontFamily="PoppinsRegular"
                 FontSize="15" 
                  >
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped" />
                                </Span.GestureRecognizers>
                            </Span>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentPage>